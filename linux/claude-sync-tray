def _load_config():
    cfg = {}
    p = Path(os.environ.get("CLAUDE_SYNC_CONFIG",
                            Path.home() / ".config/claude-sync/config"))
    if p.is_file():
        for line in p.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, v = line.split("=", 1)
            cfg[k.strip()] = v.strip().strip('"').strip("'")
    return cfg


CONF = _load_config()
WATCHER = "org.kde.StatusNotifierWatcher"
CLAUDE_ROOT = Path(os.environ.get("CS_ROOT",
                                  CONF.get("LOCAL_ROOT", Path.home() / "Claude")))
SESSION_STORE = Path(os.environ.get("CS_STORE", Path.home() / ".claude/projects"))
