def _draw_starburst(p: QPainter, size: int) -> None:
    """Fallback mark if the logo file is missing."""
    import math
    from PyQt6.QtCore import QPointF
    from PyQt6.QtGui import QPolygonF
    s = size / 64.0
    cx = cy = 30 * s
    p.setBrush(QColor(CLAUDE_TERRACOTTA))
    p.setPen(Qt.PenStyle.NoPen)
    for i in range(12):
        a = (2 * 3.141592653589793 / 12) * i - 3.141592653589793 / 2
        length = (26 if i % 2 == 0 else 19) * s
        halfw = 3.6 * s
        dx, dy = math.cos(a), math.sin(a)
        px, py = -dy, dx
        p.drawPolygon(QPolygonF([
            QPointF(cx + px * halfw, cy + py * halfw),
            QPointF(cx - px * halfw, cy - py * halfw),
            QPointF(cx + dx * length, cy + dy * length),
        ]))


def make_pixmap(color: str | None, size: int = 64) -> QPixmap:
    """Claude Code logo; optional status badge bottom-right."""
    pm = QPixmap(size, size)
    pm.fill(Qt.GlobalColor.transparent)
    p = QPainter(pm)
    p.setRenderHint(QPainter.RenderHint.Antialiasing)
    p.setRenderHint(QPainter.RenderHint.SmoothPixmapTransform)
    src = QPixmap(str(LOGO_PATH))
    if not src.isNull():
        scaled = src.scaled(size, size,
                            Qt.AspectRatioMode.KeepAspectRatio,
                            Qt.TransformationMode.SmoothTransformation)
        p.drawPixmap((size - scaled.width()) // 2,
                     (size - scaled.height()) // 2, scaled)
    else:
        _draw_starburst(p, size)
    if color is not None:
        s = size / 64.0
        r = 17 * s
        x = size - r - 1 * s
        pen = QPen(QColor("#1e1e1e"))
        pen.setWidthF(2 * s)
        p.setPen(pen)
        p.setBrush(QColor(COLORS[color]))
        p.drawEllipse(int(x), int(x), int(r), int(r))
    p.end()
    return pm


def make_icon(color: str) -> QIcon:
    return QIcon(make_pixmap(color))


def st_api(path: str):
    cfgs = [Path.home() / ".local/state/syncthing/config.xml",
            Path.home() / ".config/syncthing/config.xml"]
    cfg = next((c for c in cfgs if c.exists()), None)
    if not cfg:
        return None
    m = re.search(r"<apikey>([^<]+)</apikey>", cfg.read_text())
    if not m:
        return None
    req = urllib.request.Request(f"http://127.0.0.1:8384/rest/{path}",
                                 headers={"X-API-Key": m.group(1)})
    import json
    with urllib.request.urlopen(req, timeout=3) as r:
        return json.load(r)


def unit_active(unit: str) -> bool:
    r = subprocess.run(["systemctl", "--user", "is-active", unit],
                       capture_output=True, text=True)
    return r.stdout.strip() == "active"


def detect_renames():
    """Find session stores whose project folder no longer exists.

    Returns [(old_top_level_name, best_guess_new_name_or_None), ...]
    """
    import difflib
    prefix = str(CLAUDE_ROOT) + "/"
    orphans = []
    seen = set()
    if not SESSION_STORE.is_dir():
        return []
    for d in sorted(SESSION_STORE.iterdir()):
        if not d.is_dir():
            continue
        f = next(iter(sorted(d.glob("*.jsonl"))), None)
        if f is None:
            continue
        try:
            head = f.open("rb").read(65536).decode("utf-8", "replace")
        except OSError:
            continue
        m = re.search(r'"cwd":"([^"]+)"', head)
        if not m or not m.group(1).startswith(prefix):
            continue
        top = m.group(1)[len(prefix):].split("/")[0]
        if top in seen:
            continue
        seen.add(top)
        if not (CLAUDE_ROOT / top).exists():
            orphans.append(top)
    if not orphans:
        return []
    folders = [p.name for p in CLAUDE_ROOT.iterdir()
               if p.is_dir() and not p.name.startswith(".")]
    out = []
    for old in orphans:
        best = difflib.get_close_matches(old, folders, n=1, cutoff=0.6)
        out.append((old, best[0] if best else None))
    return out


def check_status():
    """Return (color, [status lines])."""
    lines = []
    color = "green"

    timer_ok = unit_active("claude-session-sync.timer")
    st_ok = unit_active("syncthing.service")
    if not timer_ok or not st_ok:
        color = "red"
        if not timer_ok:
            lines.append("✗ session-sync timer DOWN")
        if not st_ok:
            lines.append("✗ syncthing DOWN")

    if st_ok:
        try:
            conns = st_api("system/connections")["connections"]
            here = st_api(f"db/completion?folder={ST_FOLDER}")
            pending = here["needBytes"]
            if pending > 0:
                lines.append(f"◐ this machine: {here['completion']:.0f}% "
                             f"({pending // 1_000_000} MB left)")
            for p in PEERS:
                did = PEER_DEVICES.get(p)
                if not did:
                    continue
                p_conn = conns.get(did, {}).get("connected", False)
                d = st_api(f"db/completion?folder={ST_FOLDER}&device={did}")
                pending += d["needBytes"]
                if p_conn:
                    lines.append(f"✓ {p} connected")
                    if d["needBytes"] > 0:
                        lines.append(f"◐ {p}: {d['completion']:.0f}% "
                                     f"({d['needBytes'] // 1_000_000} MB left)")
                        if color == "green":
                            color = "amber"
                elif d["needBytes"] > 0:
                    # offline WITH data queued — worth amber attention
                    lines.append(f"● {p} offline — "
                                 f"{d['needBytes'] // 1_000_000} MB queued, "
                                 "delivers when it's back")
                    if color == "green":
                        color = "amber"
                else:
                    # offline but fully delivered — calm blue, not a warning
                    lines.append(f"○ {p} offline — nothing pending")
                    if color == "green":
                        color = "blue"
            if pending == 0:
                lines.append("✓ projects fully mirrored")
        except Exception:
            lines.append("? syncthing API not answering")
            if color == "green":
                color = "amber"

    r = subprocess.run(
        ["journalctl", "--user", "-u", "claude-session-sync.service",
         "--since", "2 hours ago", "--no-pager", "-o", "cat"],
        capture_output=True, text=True)
    transfers = [l for l in r.stdout.splitlines() if l.startswith("pulled")]
    if transfers:
        lines.append(f"✓ sessions: last run {transfers[-1]}")
    else:
        lines.append("● sessions: no transfer in 2 h (Mac away?)")

    try:
        for old, guess in detect_renames():
            lines.append(f"● '{old}' sessions orphaned (folder renamed?)")
            if color == "green":
                color = "amber"
    except Exception:
        pass

    upd = subprocess.run(
        [tool("claude-sync-check-update")],
        capture_output=True, text=True).stdout.strip()
    if upd.startswith("pull:"):
        lines.append(f"● update available ({upd[5:]} new commits) — menu → Update")
        if color == "green":
            color = "amber"
    elif upd == "reinstall":
        lines.append("● new version synced — menu → Update")

    return color, lines


class RenameDialog(QDialog):
    def __init__(self):
        super().__init__(None)
        self.setWindowTitle("Rename Claude project")
        self.result_pair = None
        self.setStyleSheet("""
            QDialog { background: #262524; }
            QLabel { color: #d8d4cf; font-size: 13px; }
            QLabel#err { color: #d84040; }
            QLabel#hint { color: #96918b; font-size: 12px; }
            QComboBox, QLineEdit { background: #33312f; color: #d8d4cf;
                border: 1px solid #454240; border-radius: 6px; padding: 4px 8px; }
            QComboBox QAbstractItemView {
                background: #2b2a28; color: #d8d4cf;
                border: 1px solid #454240;
                selection-background-color: #D97757; selection-color: #1e1e1e;
                outline: none; }
            QPushButton { background: #33312f; color: #d8d4cf;
                border: 1px solid #454240; border-radius: 8px; padding: 5px 14px; }
            QPushButton:hover { background: #3d3a38; }
        """)
        v = QVBoxLayout(self)
        v.setSpacing(8)
        v.addWidget(QLabel("Rename a project folder and migrate its sessions\n"
                           "and memory on both machines:"))
        self.combo = QComboBox()
        from PyQt6.QtWidgets import QListView
        self.combo.setView(QListView())   # stylesheet applies reliably
        self.combo.setMaxVisibleItems(18)
        try:
            folders = sorted((p.name for p in CLAUDE_ROOT.iterdir()
                              if p.is_dir() and not p.name.startswith(".")),
                             key=str.lower)
        except OSError:
            folders = []
        self.combo.addItems(folders)
        v.addWidget(self.combo)
        self.edit = QLineEdit()
        self.edit.setPlaceholderText("new name")
        v.addWidget(self.edit)
        hint = QLabel("Close any open Claude session in this project first.")
        hint.setObjectName("hint")
        v.addWidget(hint)
        self.err = QLabel("")
        self.err.setObjectName("err")
        v.addWidget(self.err)
        bb = QDialogButtonBox(QDialogButtonBox.StandardButton.Ok
                              | QDialogButtonBox.StandardButton.Cancel)
        bb.accepted.connect(self.validate_accept)
        bb.rejected.connect(self.reject)
        v.addWidget(bb)

    def validate_accept(self):
        old = self.combo.currentText()
        new = self.edit.text().strip()
        if not old:
            self.err.setText("no project selected")
            return
        if not new:
            self.err.setText("enter a new name")
            return
        if "/" in new or new.startswith("."):
            self.err.setText("invalid name")
            return
        if new == old:
            self.err.setText("that's the same name")
            return
        if (CLAUDE_ROOT / new).exists():
            self.err.setText(f"'{new}' already exists")
            return
        self.result_pair = (old, new)
        self.accept()


