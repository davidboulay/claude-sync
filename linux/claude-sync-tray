    def close_popup(self):
        self.hide()
        self.app_ref.mark_popup_closed()

    def set_lines(self, lines):
        while self.lines_box.count():
            item = self.lines_box.takeAt(0)
            if item.widget():
                item.widget().deleteLater()
        for line in lines:
            sym, _, rest = line.partition(" ")
            c = LINE_COLORS.get(sym, "#d8d4cf")
            lbl = QLabel(f'<span style="color:{c}">{sym}</span> {rest}')
            lbl.setTextFormat(Qt.TextFormat.RichText)
            self.lines_box.addWidget(lbl)

    def set_renames(self, pairs):
        while self.renames_box.count():
            item = self.renames_box.takeAt(0)
            if item.widget():
                item.widget().deleteLater()
            elif item.layout():
                sub = item.layout()
                while sub.count():
                    si = sub.takeAt(0)
                    if si.widget():
                        si.widget().deleteLater()
        for old, guess in pairs:
            row = QHBoxLayout()
            if guess:
                lbl = QLabel(f'<span style="color:#e0a030">●</span> '
                             f"renamed? <b>{old}</b> → <b>{guess}</b>")
                lbl.setTextFormat(Qt.TextFormat.RichText)
                btn = QPushButton("Repair")
                btn.clicked.connect(
                    lambda _, o=old, g=guess: self.app_ref.repair_rename(o, g))
                row.addWidget(lbl)
                row.addStretch()
                row.addWidget(btn)
            else:
                lbl = QLabel(f'<span style="color:#e0a030">●</span> '
                             f"<b>{old}</b> sessions orphaned — no matching "
                             f"folder found (claude-mv-project {old} &lt;new&gt;)")
                lbl.setTextFormat(Qt.TextFormat.RichText)
                row.addWidget(lbl)
            self.renames_box.addLayout(row)

    def event(self, e):
        if e.type() == QEvent.Type.WindowDeactivate:
            self.hide()
            self.app_ref.mark_popup_closed()
        return super().event(e)


class App:
    def __init__(self, qapp: QApplication):
        self.qapp = qapp
        self.tray = None
        self.popup = None
        self._popup_closed_at = 0.0
        self.bus = QDBusConnection.sessionBus()
        self.watcher = QDBusServiceWatcher(
            WATCHER, self.bus,
            QDBusServiceWatcher.WatchModeFlag.WatchForOwnerChange)
        self.watcher.serviceOwnerChanged.connect(self.on_owner_changed)

        self.poll = QTimer()
        self.poll.timeout.connect(self.try_create)
        self.poll.start(2000)
        self.try_create()

        self.refresh_timer = QTimer()
        self.refresh_timer.timeout.connect(self.refresh)
        self.refresh_timer.start(60_000)

    def watcher_present(self) -> bool:
        iface = self.bus.interface()
        return bool(iface and iface.isServiceRegistered(WATCHER).value())

    def try_create(self):
        if self.tray is None and self.watcher_present():
            self.create_tray()
        if self.tray is not None:
            self.poll.stop()

    def on_owner_changed(self, name, old, new):
        # panel restarted: drop and recreate the icon
        if self.tray is not None:
            self.tray.hide()
            self.tray.deleteLater()
            self.tray = None
        if new:
            QTimer.singleShot(1500, self.try_create)
        else:
            self.poll.start(2000)

    def create_tray(self):
        self.tray = QSystemTrayIcon(make_icon("gray"))
        menu = QMenu()
        a_ver = QAction(f"Claude Sync {installed_version()}", menu)
        a_ver.setEnabled(False)
        menu.addAction(a_ver)
        menu.addSeparator()
        a_pop = QAction("Status popup", menu)
        a_pop.triggered.connect(self.toggle_popup)
        a_sync = QAction("Sync sessions now", menu)
        a_sync.triggered.connect(self.sync_now)
        a_gui = QAction("Open Syncthing GUI", menu)
        a_gui.triggered.connect(lambda: subprocess.Popen(
            ["xdg-open", "http://127.0.0.1:8384"]))
        a_upd = QAction("Update Claude Sync", menu)
        a_upd.triggered.connect(self.update_now)
        a_term = QAction("Full status (terminal)", menu)
        a_term.triggered.connect(self.open_terminal_status)
        a_quit = QAction("Quit", menu)
        a_quit.triggered.connect(self.qapp.quit)
        for a in (a_pop, a_sync, a_gui, a_upd, a_term):
            menu.addAction(a)
        menu.addSeparator()
        menu.addAction(a_quit)
        self.menu = menu
        self.tray.setContextMenu(menu)
        self.tray.activated.connect(self.on_activated)
        self.tray.show()
        self.refresh()

    def on_activated(self, reason):
        if reason == QSystemTrayIcon.ActivationReason.Trigger:
            self.toggle_popup()

    def mark_popup_closed(self):
        self._popup_closed_at = time.monotonic()

    def toggle_popup(self):
        now = time.monotonic()
        if self.popup is not None and self.popup.isVisible():
            self.popup.hide()
            self.mark_popup_closed()
            return
        # the click that dismissed the popup may also reach the tray icon;
        # don't instantly reopen
        if now - self._popup_closed_at < 0.4:
            return
        if self.popup is None:
            self.popup = StatusPopup(self)
        color, lines = check_status()
        if self.tray is not None:
            self.tray.setIcon(make_icon(color))
            self.tray.setToolTip("Claude sync\n" + "\n".join(lines))
        self.popup.set_lines(lines)
        try:
            self.popup.set_renames(detect_renames())
        except Exception:
            self.popup.set_renames([])
        try:
            upd = (Path.home() / ".local/share/claude-sync/.update-check").read_text().strip()
        except OSError:
            upd = "ok"
        self.popup.b_update.setVisible(upd.startswith("pull") or upd == "reinstall")
        self.popup.adjustSize()
        # cursor coordinates are unreliable under Wayland/XWayland when the
        # click lands on the native panel — anchor to the panel corner instead
        geo = self.qapp.primaryScreen().availableGeometry()
        self.popup.move(geo.right() - self.popup.width() - 12, geo.top() + 12)
        self.popup.show()
        self.popup.raise_()
        self.popup.activateWindow()

    def update_now(self):
        def run():
            r = subprocess.run(
                [tool("claude-sync-check-update"), "--apply"],
                capture_output=True, text=True, timeout=600)
            ok = r.returncode == 0
            subprocess.Popen(
                ["notify-send", "-i", str(LOGO_PATH), "Claude Sync",
                 r.stdout.strip()[-120:] if ok else
                 f"update failed: {(r.stderr or r.stdout).strip()[-120:]}"])
            if ok:
                # binary on disk was replaced — re-exec ourselves onto it
                os.execv(sys.executable,
                         [sys.executable, tool("claude-sync-tray")])

        import threading
        threading.Thread(target=run, daemon=True).start()

    def open_terminal_status(self):
        subprocess.Popen(["cosmic-term", "-e",
                          tool("claude-sync-status"),
                          "--wait"])

    def rename_project_flow(self):
        if self.popup is not None:
            self.popup.hide()
            self.mark_popup_closed()
        dlg = RenameDialog()
        if dlg.exec() == QDialog.DialogCode.Accepted and dlg.result_pair:
            self.repair_rename(*dlg.result_pair)

    def repair_rename(self, old, new):
        if self.popup is not None:
            self.popup.hide()
            self.mark_popup_closed()

        def run():
            r = subprocess.run(
                [tool("claude-mv-project"), old, new],
                capture_output=True, text=True, timeout=300)
            ok = r.returncode == 0
            subprocess.Popen(
                ["notify-send", "-i", str(LOGO_PATH), "Claude Sync",
                 (f"Repaired: {old} → {new}" if ok else
                  f"Repair FAILED for {old} → {new}\n{r.stderr.strip()[-200:]}")])

        import threading
        threading.Thread(target=run, daemon=True).start()
        QTimer.singleShot(10_000, self.refresh)

    def sync_now(self):
        subprocess.Popen([tool("claude-session-translate")],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        QTimer.singleShot(5000, self.refresh)

    def refresh(self):
        if self.tray is None:
            return
        try:
            color, lines = check_status()
        except Exception as e:
            color, lines = "gray", [f"? status check failed: {e}"]
        self.tray.setIcon(make_icon(color))
        self.tray.setToolTip("Claude sync\n" + "\n".join(lines))
        if self.popup is not None and self.popup.isVisible():
            self.popup.set_lines(lines)
        # notify once when an update first becomes available (check_status
        # already triggered the cached checker)
        try:
            upd = (Path.home() / ".local/share/claude-sync/.update-check").read_text().strip()
        except OSError:
            upd = "ok"
        actionable = upd.startswith("pull") or upd == "reinstall"
        if actionable and getattr(self, "_last_upd", "ok") != upd:
            subprocess.Popen(
                ["notify-send", "-i", str(LOGO_PATH), "Claude Sync",
                 "Update available — open the popup and hit “Update now”"])
        self._last_upd = upd


def main():
    if len(sys.argv) >= 4 and sys.argv[1] == "--render-icon":
        os.environ["QT_QPA_PLATFORM"] = "offscreen"
        qapp = QApplication(sys.argv)
        size, out = int(sys.argv[2]), sys.argv[3]
        make_pixmap(None, size).save(out, "PNG")
        print(f"wrote {out}")
        return
    if len(sys.argv) >= 5 and sys.argv[1] == "--render-badge":
        os.environ["QT_QPA_PLATFORM"] = "offscreen"
        qapp = QApplication(sys.argv)
        state, size, out = sys.argv[2], int(sys.argv[3]), sys.argv[4]
        make_pixmap(state, size).save(out, "PNG")
        print(f"wrote {out}")
        return

    # xcb (XWayland) so the popup can be cursor-positioned and focused;
    # the tray icon itself is D-Bus and works the same either way
    os.environ.setdefault("QT_QPA_PLATFORM", "xcb")
    qapp = QApplication(sys.argv)
    qapp.setQuitOnLastWindowClosed(False)
    app = App(qapp)          # keep a reference or Python GCs the tray
    sys.exit(qapp.exec())


if __name__ == "__main__":
    main()
