PEERS = CONF.get("PEERS", "").split()
PEER_DEVICES = {p: CONF.get(f"PEER_DEVICE_{p}", "") for p in PEERS}


def tool(name):
    return shutil.which(name) or str(Path.home() / ".local/bin" / name)


def installed_version():
    base = Path.home() / ".local/share/claude-sync"
    rel = h = ""
    try:
        rel = (base / "installed-release").read_text().strip()
    except OSError:
        try:  # system-wide (.deb) install
            rel = Path("/usr/share/claude-sync/VERSION").read_text().strip()
        except OSError:
            pass
    try:
        h = (base / "installed-version").read_text().strip()[:7]
    except OSError:
        pass
    return f"v{rel}" + (f" ({h})" if h else "") if rel else (h or "dev")
